# Copy this file to `.env` and fill in your real credentials.
# Do not commit `.env` with secrets.

# Required
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret

# Optional (defaults shown)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_LIVE_FEED=iex
# Optional websocket overrides; usually leave unset and let alpaca-py choose.
# ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
# ALPACA_TRADING_STREAM_URL=wss://paper-api.alpaca.markets/stream
DATA_DIR=./data
TZ=America/New_York

# Optional live runtime defaults
# LIVE_SYMBOL=SPY
# LIVE_VARIANTS=baseline,soft_hybrid_7_5,soft_hybrid_10,soft_hybrid_5
